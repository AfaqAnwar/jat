# Convex deployment URL (public, exposed to the client)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Auth provider domain (set automatically by Convex, used in convex/auth.config.ts)
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Gemini API key for AI-powered job parsing (server-side only, set in Convex dashboard)
# GEMINI_API_KEY=your-gemini-api-key
