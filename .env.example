# Convex deployment URL (public, exposed to the client via Vite)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ──────────────────────────────────────────────────────
# The following variables are set in the Convex dashboard
# (Settings > Environment Variables), NOT in this file.
# ──────────────────────────────────────────────────────

# Auth provider domain (set automatically by Convex for OAuth callbacks)
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Gemini API key for AI-powered job parsing (server-side only)
# GEMINI_API_KEY=your-gemini-api-key

# GitHub OAuth (set in Convex dashboard, register at https://github.com/settings/developers)
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth (set in Convex dashboard, register at https://console.cloud.google.com/apis/credentials)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
